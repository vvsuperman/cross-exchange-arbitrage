# 风控守护进程 strategy/arb_risk_manager.py
# 在 arb.env 之后加载，同名变量以本文件为准（override）。

# 主动探测：盘口深度里看到探测单时的往返延迟超过此值则置位风险码[1]
STALE_THRESHOLD_MS=8000

# REST orderbook endVersion 与 Redis 中 WS BBO endVersion 的允许最大落后（版本差）
VERSION_LAG_THRESHOLD=15

# REST 轮询间隔（秒）
REST_POLL_INTERVAL_SEC=2
# REST 拉 orderbook 的 depth 档数；勿用 1，EdgeX 返回 INVALID_DEPTH_LEVEL（与 edgex.py / monitor 常用 15 一致）
REST_DEPTH_LIMIT=15

# 主动探测下单间隔（秒）
PROBE_INTERVAL_SEC=60

# 探测限价买单：best_bid * PROBE_PRICE_RATIO；时间有效性 FOK（Fill Or Kill），不残留挂单
# 探测完成判定：私有 ORDER_UPDATE（含 CANCELED 等终态）
PROBE_PRICE_RATIO=0.3

# 持续刷新 Redis 风险码的循环间隔（秒）；应小于 RISK_REDIS_TTL_SEC
RISK_HEARTBEAT_INTERVAL_SEC=1

# 公共 WS 距上一笔消息的间隔超过此值（毫秒）视为到达延迟风险码[2]
ARRIVAL_LATENCY_THRESHOLD_MS=50

# 传输层 ping/pong RTT 超过此值（毫秒）视为风险码[3]
PING_LATENCY_THRESHOLD_MS=100

# 同类异常写入 CSV 的最小间隔（秒），防抖
ANOMALY_LOG_DEBOUNCE_SEC=1.0

# Redis 风险码 TTL（秒）
RISK_REDIS_TTL_SEC=5

# 各指标汇总打印间隔（秒），0 表示关闭
RISK_METRICS_LOG_INTERVAL_SEC=60
